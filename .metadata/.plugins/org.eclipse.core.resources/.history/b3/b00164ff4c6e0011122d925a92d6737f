#include <stdint.h>
#include <stdio.h>
#include "gpio_driver.h"
#include "rcc_driver.h"
#include "usart_driver.h"
#include "systick.h"
#include "i2c_scanner.h"

#define DWT_CTRL 		(*(volatile uint32_t*)0xE0001000)
#define DWT_CYCCNT	(*(volatile uint32_t*)0xE0001004)
#define DEMCR_REG		(*(volatile uint32_t*)0xE000EDFC)

int main(void)
{
	DEMCR_REG |= (1 << 24);
	DWT_CTRL |= (1 << 0);
	DWT_CYCCNT = 0;

	SysTick_Init();

	GPIO_PeriClockControl(GPIOB, ENABLE);

	GPIO_Handle_t I2CPins;
	I2CPins.pGPIOx = GPIOB;
	I2CPins.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_ALT;
	I2CPins.GPIO_PinConfig.GPIO_PinAltFunMode = 4;
	I2CPins.GPIO_PinConfig.GPIO_PinOPType = GPIO_OPTYPE_OD;
	I2CPins.GPIO_PinConfig.GPIO_PinPuPdControl = GPIO_PU;
	I2CPins.GPIO_PinConfig.GPIO_PinSpeed = GPIO_SPEED_FAST;

	I2CPins.GPIO_PinConfig.GPIO_PinNumber = GPIO_PIN_NO_6;
	GPIO_Init(&I2CPins);

	I2CPins.GPIO_PinConfig.GPIO_PinNumber = GPIO_PIN_NO_7;
	GPIO_Init(&I2CPins);

	I2C_Handle_t I2C1Handle;
	I2C1Handle.pI2Cx = I2C1;
	I2C1Handle.I2C_Config.I2C_SCLspeed = I2C_SCL_SPEED_FM4K;
	I2C1Handle.I2C_Config.I2C_DeviceAddress = 0x30;
	I2C1Handle.I2C_Config.I2C_AckControl = I2C_ACK_ENABLE;
	I2C1Handle.I2C_Config.FMDutyCycle = I2C_FM_DUTY_2;
	// Standard라 DUTY는 쓰이지 않음.

	I2C_Init(&I2C1Handle);

	I2C_PeripheralControl(I2C1, ENABLE);

	uint32_t cyc_start = DWT_CYCCNT;
	I2C_AddressScan(&I2C1Handle);
	uint32_t cyc_total = DWT_CYCCNT - cyc_start;

	uint32_t ms_whole = cyc_total / (SystemCoreClock / 1000);
	uint32_t ms_frac = (cyc_total % (SystemCoreClock / 1000)) * 100 / (SystemCoreClock / 1000);
	printf("Total Scan: %lu cycles, %lu.%02lu ms\r\n", cyc_total, ms_whole, ms_frac);

	while(1)
	{


	}

}
