#include <stdint.h>
#include <stdio.h>
#include <string.h>   //strncmp 추가
#include "gpio_driver.h"
#include "rcc_driver.h"
#include "usart_driver.h"
#include "systick.h"


int main(void)
{
	SysTick_Init();

	GPIO_PeriClockControl(GPIOA, ENABLE);

	GPIO_Handle_t GpioLed = {0};
	GpioLed.pGPIOx									= GPIOA;
	GpioLed.GPIO_PinConfig.GPIO_PinMode			= GPIO_MODE_OUTPUT;
	GpioLed.GPIO_PinConfig.GPIO_PinSpeed			= GPIO_SPEED_LOW;
	GpioLed.GPIO_PinConfig.GPIO_PinOPType			= GPIO_OPTYPE_PP;
	GpioLed.GPIO_PinConfig.GPIO_PinPuPdControl	= GPIO_NO_PUPD;
	GpioLed.GPIO_PinConfig.GPIO_PinNumber			= GPIO_PIN_NO_5;
	GPIO_Init(&GpioLed);


	GPIO_Handle_t GpioUart = {0};
	GpioUart.pGPIOx									= GPIOA;
	GpioUart.GPIO_PinConfig.GPIO_PinMode			= GPIO_MODE_ALT;
	GpioUart.GPIO_PinConfig.GPIO_PinSpeed			= GPIO_SPEED_FAST;
	GpioUart.GPIO_PinConfig.GPIO_PinOPType			= GPIO_OPTYPE_PP;
	GpioUart.GPIO_PinConfig.GPIO_PinPuPdControl 	= GPIO_PU;
	GpioUart.GPIO_PinConfig.GPIO_PinAltFunMode	= 7;
	GpioUart.GPIO_PinConfig.GPIO_PinNumber = GPIO_PIN_NO_2;
	GPIO_Init(&GpioUart);

	GpioUart.GPIO_PinConfig.GPIO_PinNumber = GPIO_PIN_NO_3;
	GPIO_Init(&GpioUart);


	USART_Handle_t usart2Handle = {0};
	usart2Handle.pUSARTx									= USART2;
	usart2Handle.USART_Config.USART_Mode				= USART_MODE_TX_RX;
	usart2Handle.USART_Config.USART_Baud				= USART_STD_BAUD_115200;
	usart2Handle.USART_Config.USART_NoOfStopBits		= USART_STOPBITS_1;
	usart2Handle.USART_Config.USART_WordLength		= USART_WORDLEN_8BITS;
	usart2Handle.USART_Config.USART_ParityControl		= USART_PARITY_DISABLE;
	usart2Handle.USART_Config.USART_HWFlowControl		= USART_HW_FLOW_CTRL_NONE;
	USART_Init(&usart2Handle);

	uint8_t cmd[16];
	uint8_t byte;
	uint8_t ledstate = 0;

	while(1)
	{
		idx = 0;
		memset(cmd, 0, sizeof(cmd));

		while(idx < sizeof(cmd) - 1)
		{
			USART_ReceiveData(&usart2Handle, &byte, 1);
			if(byte == '\n') break;
			if(byte == '\r') continue;
			cmd[idx++] = byte;
		}
		cmd[idx] = '\0';

		USART_ReceiveData(&usart2Handle, cmd, 10);

		if(strncmp((char*)cmd, "LED ON", 6) == 0)
		{
			ledstate = 1;
			GPIO_WriteToOutputPin(GPIOA, GPIO_PIN_NO_5, GPIO_PIN_SET);
			USART_SendData(&usart2Handle,
					(uint8_t*)"[OK] LED ON\r\n", 13);
		}
		else if(strncmp((char*)cmd, "LED OFF", 7) == 0)
		{
			ledstate = 0;
			GPIO_WriteToOutputPin(GPIOA, GPIO_PIN_NO_5, GPIO_PIN_RESET);
			USART_SendData(&usart2Handle,
					(uint8_t*)"[OK] LED OFF\r\n", 14);
		}
		else if(strncmp((char*)cmd, "STATUS", 6) == 0)
		{
			if(ledstate)
			{
				USART_SendData(&usart2Handle,
						(uint8_t*)"LED: ON\r\n", 9);
			}else{
				USART_SendData(&usart2Handle,
						(uint8_t*)"LED: OFF\r\n", 10);
			}
		}
		else
		{
			USART_SendData(&usart2Handle,
					(uint8_t*)"[UNKNOWN ERR]", 13);
		}
	}
}




