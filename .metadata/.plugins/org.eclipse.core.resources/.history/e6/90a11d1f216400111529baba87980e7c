#include <stdint.h>
#include <stdio.h>
#include "gpio_driver.h"
#include "rcc_driver.h"
#include "usart_driver.h"
#include "systick.h"

#if !defined(__SOFT_FP__) && defined(__ARM_FP)
  #warning "FPU is not initialized, but the project is compiling for an FPU. Please initialize the FPU before use."
#endif

int main(void)
{
	SysTick_Init();

	GPIO_PeriClockControl(GPIOA, ENABLE);

	GPIO_Handle_t GpioLed = {0};
	GpioLed.pGPIOx									= GPIOA;
	GpioLed.GPIO_PinConfig.GPIO_PinMode			= GPIO_MODE_OUTPUT;
	GpioLed.GPIO_PinConfig.GPIO_PinSpeed			= GPIO_SPEED_LOW;
	GpioLed.GPIO_PinConfig.GPIO_PinOPType			= GPIO_OPTYPE_PP;
	GpioLed.GPIO_PinConfig.GPIO_PinPuPdControl	= GPIO_NO_PUPD;
	GpioLed.GPIO_PinConfig.GPIO_PinNumber			= GPIO_PIN_NO_5;
	GPIO_Init(&GpioLed);

	GPIO_PeriClockControl(GPIOC, ENABLE);

	GPIO_Handle_t GpioUart1 = {0};
	GpioUart1.pGPIOx									= GPIOC;
	GpioUart1.GPIO_PinConfig.GPIO_PinMode			= GPIO_MODE_ALT;
	GpioUart1.GPIO_PinConfig.GPIO_PinSpeed			= GPIO_SPEED_FAST;
	GpioUart1.GPIO_PinConfig.GPIO_PinOPType		= GPIO_OPTYPE_PP;
	GpioUart1.GPIO_PinConfig.GPIO_PinPuPdControl 	= GPIO_PU;
	GpioUart1.GPIO_PinConfig.GPIO_PinAltFunMode	= 7;
	GpioUart1.GPIO_PinConfig.GPIO_PinNumber = GPIO_PIN_NO_11;
	GPIO_Init(&GpioUart1);

	USART_Handle_t usart3HandleR = {0};
	usart3HandleR.pUSARTx								= USART3;
	usart3HandleR.USART_Config.USART_Mode				= USART_MODE_ONLY_RX;
	usart3HandleR.USART_Config.USART_Baud				= USART_STD_BAUD_115200;
	usart3HandleR.USART_Config.USART_NoOfStopBits		= USART_STOPBITS_1;
	usart3HandleR.USART_Config.USART_WordLength		= USART_WORDLEN_8BITS;
	usart3HandleR.USART_Config.USART_ParityControl	= USART_PARITY_DISABLE;
	usart3HandleR.USART_Config.USART_HWFlowControl	= USART_HW_FLOW_CTRL_NONE;
	USART_Init(&usart3HandleR);

//	USART3->BRR = 125;

	uint32_t feCount = 0;
	uint32_t oreCount = 0;

	while(1)
	{
		if(USART_GetFlagStatus(USART3, USART_SR_FE))
		{
			feCount++;
			GPIO_ToggleOutputPin(GPIOA, GPIO_PIN_NO_5);
			(void)USART3->SR;
			(void)USART3->DR;
		}
		if(USART_GetFlagStatus(USART3, USART_SR_ORE))
		{
			oreCount++;
			GPIO_ToggleOutputPin(GPIOA, GPIO_PIN_NO_5);
			(void)USART3->SR;
			(void)USART3->DR;
		}

		Delay_ms(10);
	}
}



