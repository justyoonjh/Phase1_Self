#include "gpio_driver.h"

void PeriClockControl(GPIO_RegMap_t *pGPIOx, uint8_t EnorDi)
{
	if (EnorDi == 1)
	{
		if (pGPIOx == GPIOA) { GPIOA_CLK_EN(); }
		else if (pGPIOx == GPIOB) { GPIOB_CLK_EN(); }
		else if (pGPIOx == GPIOC) { GPIOC_CLK_EN(); }
	}
	else
	{

	}
}
