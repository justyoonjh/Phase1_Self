#include <stdint.h>
#include <stdio.h>
#include "gpio_driver.h"


#if !defined(__SOFT_FP__) && defined(__ARM_FP)
  #warning "FPU is not initialized, but the project is compiling for an FPU. Please initialize the FPU before use."
#endif

volatile uint8_t isr_order[10] = {0};
volatile uint8_t isr_cnt			= 0;


int main(void)
{
	setvbuf(stdout, NULL, _IONBF, 0);

	GPIO_Handle_t GpioLed;
	GpioLed.pGPIOx											= GPIOA;
	GpioLed.GPIO_PinConfig.GPIO_PinNumber					= GPIO_PIN_NO_5;
	GpioLed.GPIO_PinConfig.GPIO_PinMode					= GPIO_MODE_OUTPUT;
	GpioLed.GPIO_PinConfig.GPIO_PinSpeed					= GPIO_SPEED_LOW;
	GpioLed.GPIO_PinConfig.GPIO_PinOPType					= GPIO_OPTYPE_PP;
	GpioLed.GPIO_PinConfig.GPIO_PinPuPdControl			= GPIO_NO_PUPD;

	GPIO_PeriClockControl(GPIOA, 1);
	GPIO_Init(&GpioLed);

	GPIO_Handle_t GpioBtn;
	GpioBtn.pGPIOx											= GPIOC;
	GpioBtn.GPIO_PinConfig.GPIO_PinNumber					= GPIO_PIN_NO_13;
	GpioBtn.GPIO_PinConfig.GPIO_PinMode					= GPIO_MODE_IT_FT;
	GpioBtn.GPIO_PinConfig.GPIO_PinSpeed					= GPIO_SPEED_LOW;
	GpioBtn.GPIO_PinConfig.GPIO_PinOPType					= GPIO_OPTYPE_PP;
	GpioBtn.GPIO_PinConfig.GPIO_PinPuPdControl			= GPIO_NO_PUPD;

	GPIO_PeriClockControl(GPIOC, 1);
	GPIO_Init(&GpioBtn);

	GPIO_Handle_t GpioExt;
	GpioExt.pGPIOx											= GPIOA;
	GpioExt.GPIO_PinConfig.GPIO_PinNumber					= GPIO_PIN_NO_0;
	GpioExt.GPIO_PinConfig.GPIO_PinMode					= GPIO_MODE_IT_FT;
	GpioExt.GPIO_PinConfig.GPIO_PinSpeed					= GPIO_SPEED_LOW;
	GpioExt.GPIO_PinConfig.GPIO_PinOPType					= GPIO_OPTYPE_PP;
	GpioExt.GPIO_PinConfig.GPIO_PinPuPdControl			= GPIO_PU;
	GPIO_Init(&GpioExt);

	GPIO_IRQConfig(EXTI15_10_IRQ, 6, 1);
	GPIO_IRQConfig(EXTI0_IRQ, 3, 1);

	printf("===Priority Test===\r\n");
	printf("PC13 priority=6, PA0 priority=3\r\n");
	printf("Press both buttons simultaneously\r\n");

	while(1)
	{

		if (isr_cnt >= 2)
		{
			printf("Order: %d -> %d\r\n", isr_order[0], isr_order[1]);

			isr_cnt = 0;
			isr_order[0] = 0;
			isr_order[1] = 0;
		}
	}
}

void EXTI15_10_IRQHandler(void)
{
	GPIO_IRQHandling(GPIO_PIN_NO_13);
	if (isr_cnt < 10)
		isr_order[isr_cnt++] = 1;

	for (volatile uint32_t i = 0; i < 200000000; i++);
}

void EXTI0_IRQHandler(void)
{
	GPIO_IRQHandling(GPIO_PIN_NO_0);
	if (isr_cnt < 10)
		isr_order[isr_cnt++] = 2;
}
