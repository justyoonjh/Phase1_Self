typedef enum {
	PKT_WAIT_STX,
	PKT_WAIT_LEN,
	PKT_WAIT_DATA,
	PKT_WAIT_ETX
}PktState_t;

uint8_t USART_ReceivePacket(USART_Handle_t *pHandle, uint8_t *outBuf, uint8_t *outLen)
{
	uint8_t byte;
	PktState_t state = PKT_WAIT_STX;
	uint8_t dataLen = 0;
	uint8_t received = 0;

	while(1)
	{
		USART_ReceiveData(pHandle, &byte, 1);

		switch(state)
		{
		case PKT_WAIT_STX:
			if(byte == 0x02) state = PKT_WAIT_LEN;
			break;
		case PKT_WAIT_LEN:
			dataLen = byte;
			received = 0;
			state = PKT_WAIT_DATA;
			break;
		case PKT_WAIT_DATA:
			outBuf[received++] = byte;
			if(received == dataLen) state = PKT_WAIT_ETX;
			break;
		case PKT_WAIT_ETX:
			outBuf[received] = '\0';
			*outLen = dataLen;
			if(byte == 0x03) return 1;
			else			   return 0;

		}
	}
}

