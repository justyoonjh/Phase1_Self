#include <stdint.h>
#include <stdio.h>
#include "gpio_driver.h"
#include "systick.h"
#include "keypad_driver.h"

#if !defined(__SOFT_FP__) && defined(__ARM_FP)
  #warning "FPU is not initialized, but the project is compiling for an FPU. Please initialize the FPU before use."
#endif

uint32_t last_key_time = 0;
#define KEY_COOLDOWN_MS 200
#define PIN_LENGTH 4
#define LOCK_TIME_MS 5000

static const char CORRECT_PIN[PIN_LENGTH] = {'2', '6', '2', '6'};

int main(void)
{
	SysTick_Init();

	GPIO_Handle_t GpioLed = {0};
	GpioLed.pGPIOx											= GPIOA;
	GpioLed.GPIO_PinConfig.GPIO_PinNumber					= GPIO_PIN_NO_5;
	GpioLed.GPIO_PinConfig.GPIO_PinMode					= GPIO_MODE_OUTPUT;
	GpioLed.GPIO_PinConfig.GPIO_PinSpeed					= GPIO_SPEED_LOW;
	GpioLed.GPIO_PinConfig.GPIO_PinOPType					= GPIO_OPTYPE_PP;
	GpioLed.GPIO_PinConfig.GPIO_PinPuPdControl			= GPIO_NO_PUPD;
	GpioLed.GPIO_PinConfig.GPIO_PinAltFunMode				= 0;
	GPIO_PeriClockControl(GPIOA, 1);
	GPIO_Init(&GpioLed);

	Keypad_Init();

	setvbuf(stdout, NULL, _IONBF, 0);
	printf("System ready. Enter PIN:\n");

	char input[PIN_LENGTH];
	uint8_t input_idx = 0;
	uint8_t locked = 0;
	uint32_t lock_start = 0;
	uint32_t prev_lock_print = 0;

	while(1)
	{
		if (locked)
		{
			uint32_t elapsed = GetTick() - lock_start;

			if (elapsed >= LOCK_TIME_MS)
			{
				locked = 0;
				input_idx = 0;
				printf("Unlocked. Enter PIN:\n");
			}
			else
			{
				if ((GetTick() - prev_lock_print) >= 1000)
				{
					uint32_t remaining = (LOCK_TIME_MS - elapsed) / 1000;
					printf("Locked. %lu sec remaining...\n", remaining);
					prev_lock_print = GetTick();
				}
			}
			continue;
		}

		char key = Keypad_Getkey();
		if (key == 0) continue;

		if ((GetTick() - last_key_time) < KEY_COOLDOWN_MS) continue;

		last_key_time = GetTick();

		printf("Input: %c\n", key);
		input[input_idx++] = key;

		if (input_idx >= PIN_LENGTH)
		{
			uint8_t correct = 1;
			for (int i = 0; i < PIN_LENGTH; i++)
			{
				if (input[i] != CORRECT_PIN[i])
				{
					correct = 0;
					break;
				}
			}

			if (correct)
			{
				printf("PIN correct! LED ON. \n");
				GPIO_WriteToOutputPin(GPIOA, GPIO_PIN_NO_5, GPIO_PIN_SET);
			}
			else
			{
				printf("Wrong PIN. Locked for %d sec. \n", LOCK_TIME_MS / 1000);
				GPIO_WriteToOutputPin(GPIOA, GPIO_PIN_NO_5, GPIO_PIN_RESET);
				locked = 1;
				lock_start = GetTick();
				prev_lock_print = GetTick();
			}

			input_idx = 0;
		}
	}

}
